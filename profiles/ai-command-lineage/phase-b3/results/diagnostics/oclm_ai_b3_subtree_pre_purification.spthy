lemma action_certificate_requires_authority_authorized_action:
  "All authority_pk verifier_pk command_id epoch
       agent_c_pk action_id tool arguments
       child_scope action_certificate
       #c.

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     ==>

     (Ex allowed_action_digest #a.

       ExecutionScopeIssued(
         authority_pk,
         command_id,
         epoch,
         child_scope,
         allowed_action_digest
       ) @ #a

       &

       allowed_action_digest =
         h(<tool, arguments>)

       & #a < #c)"


lemma compromised_leaf_certificate_still_requires_authorized_action:
  "All authority_pk verifier_pk command_id epoch
       agent_c_pk action_id tool arguments
       child_scope action_certificate
       #k #p #c.

     AgentCompromised(
