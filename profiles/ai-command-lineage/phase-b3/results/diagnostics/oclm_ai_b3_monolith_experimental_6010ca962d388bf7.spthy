lemma action_certificate_single_use_under_compromise:
  "All action_certificate epoch_1 epoch_2 #i #j.

     ActionCertificateConsumed(
       action_certificate,
       epoch_1
     ) @ #i

     &

     ActionCertificateConsumed(
       action_certificate,
       epoch_2
     ) @ #j

     ==>

     #i = #j"



