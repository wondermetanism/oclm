/* =========================================================================
 * Replacement subtree.
 *
 * A revoked certified B -> C branch is not resurrected.
 * Authority creates fresh B' and C' identities and fresh descendant scopes.
 * ========================================================================= */

rule Authority_Replace_Revoked_Certified_Subtree:
  let
    new_child_scope_1 =
      attenuate(
        root_scope,
        ~replacement_restriction_1
      )

    new_child_scope_2 =
      attenuate(
        new_child_scope_1,
        ~replacement_restriction_2
      )

    replacement_certificate =
      sign(
        <'oclm-ai-b3-subtree-replacement-v1',
         pk(authority_sk),
         command_id,
         epoch,
         old_agent_b_pk,
         old_agent_c_pk,
         pk(~replacement_b_sk),
         pk(~replacement_c_sk),
         old_child_scope_2,
         new_child_scope_2>,
        authority_sk
      )
  in

  [
    !AuthoritySecret(authority_sk),

    !ControlLineage(
      pk(authority_sk),
      command_id,
      epoch,
      agent_a_pk,
      old_agent_b_pk,
      old_agent_c_pk,
      verifier_pk,
      root_scope,
      old_child_scope_1,
      old_child_scope_2
    ),

    !AllowedActionDigest(
      pk(authority_sk),
      command_id,
      epoch,
      old_child_scope_2,
      allowed_action_digest
    ),

    !AuthorizedAction(
      pk(authority_sk),
      command_id,
      epoch,
      old_child_scope_2,
      allowed_tool,
      allowed_arguments
    ),

    !RevokedSubtree(
      pk(authority_sk),
      command_id,
      epoch,
      old_agent_b_pk,
      old_agent_c_pk
    ),

    ReplacementGenerationBudget(
      pk(authority_sk),
      command_id
    ),


    SubtreeReplacementPermit(
      pk(authority_sk),
      command_id,
      epoch,
      old_agent_b_pk,
      old_agent_c_pk
    ),

    CommandState(
      pk(authority_sk),
      command_id,
      epoch,
      'certified'
    ),

    Fr(~replacement_b_sk),
    Fr(~replacement_c_sk),
    Fr(~replacement_restriction_1),
    Fr(~replacement_restriction_2)
  ]
  --[
    ReplacementGenerationConsumed(
      pk(authority_sk),
      command_id,
      epoch
    ),


    SubtreeReplacementIssued(
      pk(authority_sk),
      command_id,
      epoch,
      old_agent_b_pk,
      old_agent_c_pk,
      pk(~replacement_b_sk),
      pk(~replacement_c_sk),
      old_child_scope_2,
      new_child_scope_2,
      replacement_certificate
    ),

    ExecutionScopeIssued(
      pk(authority_sk),
      command_id,
      epoch,
      new_child_scope_2,
      allowed_action_digest
    )
  ]->
  [
    !AgentSecret(
      'agent-b',
      ~replacement_b_sk
    ),

    !AgentSecret(
      'agent-c',
      ~replacement_c_sk
    ),

    !ControlLineage(
      pk(authority_sk),
      command_id,
      epoch,
      agent_a_pk,
      pk(~replacement_b_sk),
      pk(~replacement_c_sk),
      verifier_pk,
      root_scope,
      new_child_scope_1,
      new_child_scope_2
    ),

    !AllowedActionDigest(
      pk(authority_sk),
      command_id,
      epoch,
      new_child_scope_2,
      allowed_action_digest
    ),

    !AuthorizedAction(
      pk(authority_sk),
      command_id,
      epoch,
      new_child_scope_2,
      allowed_tool,
      allowed_arguments
    ),

    !ReplacementSubtreeRecord(
      pk(authority_sk),
      command_id,
      epoch,
      old_agent_b_pk,
      old_agent_c_pk,
      pk(~replacement_b_sk),
      pk(~replacement_c_sk),
      old_child_scope_2,
      new_child_scope_2
    ),

    SubtreeLifecyclePermit(
      pk(authority_sk),
      command_id,
      epoch,
      pk(~replacement_b_sk),
      pk(~replacement_c_sk),
      'delegated-ready'
    ),

    CommandState(
      pk(authority_sk),
      command_id,
      epoch,
      'delegated-ready'
    ),

    Out(
      <'oclm-ai-b3-subtree-replacement-v1',
       replacement_certificate>
    )
  ]


/* =========================================================================
 * Reachability / health.
 * ========================================================================= */

lemma executable_honest_current_epoch_action:
  exists-trace
  "Ex authority_pk verifier_pk command_id epoch
      agent_a_pk agent_b_pk agent_c_pk
      action_id tool arguments
      root_scope child_scope_1 child_scope
      action_certificate
      #r #p #c #e.

     ControlledCommandIssued(
       authority_pk,
       command_id,
       epoch,
       agent_a_pk,
       agent_b_pk,
       agent_c_pk,
       verifier_pk,
       root_scope,
       child_scope_1,
       child_scope
     ) @ #r

     &

     HonestActionProposed(
       authority_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope
     ) @ #p

     &

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     &

     ToolExecutionAccepted(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #e

     & #r < #p
     & #p < #c
     & #c < #e"


lemma emergency_stop_after_certificate_is_reachable:
  exists-trace
  "Ex authority_pk verifier_pk command_id epoch
      agent_c_pk action_id tool arguments
      child_scope action_certificate stop_certificate
      #c #s.

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     &

     EmergencyStopIssued(
       authority_pk,
       command_id,
       epoch,
       'certified',
       stop_certificate
     ) @ #s

     & #c < #s"


lemma compromised_leaf_can_be_stopped:
  exists-trace
  "Ex authority_pk command_id epoch
      agent_c_pk action_id tool arguments
      child_scope stop_certificate
      #k #p #s.

     AgentCompromised(
       'agent-c',
       agent_c_pk
     ) @ #k

     &

     CompromisedActionProposed(
       authority_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope
     ) @ #p

     &

     EmergencyStopIssued(
       authority_pk,
       command_id,
       epoch,
       'proposed',
       stop_certificate
     ) @ #s

     & #k < #p
     & #p < #s"


lemma stopped_command_can_restart_only_under_new_epoch:
  exists-trace
  "Ex authority_pk command_id
      old_epoch new_epoch stop_certificate
      #s #r.

     EmergencyStopIssued(
       authority_pk,
       command_id,
       old_epoch,
       'certified',
       stop_certificate
     ) @ #s

     &

     CommandEpochRestarted(
       authority_pk,
       command_id,
       old_epoch,
       new_epoch
     ) @ #r

     & #s < #r"



/* =========================================================================
 * Security properties.
 * ========================================================================= */

lemma emergency_stop_blocks_later_execution:
  "All authority_pk verifier_pk command_id epoch
       agent_c_pk action_id tool arguments
       child_scope action_certificate
       stopped_state stop_certificate
       #s #e.

     EmergencyStopIssued(
       authority_pk,
       command_id,
       epoch,
       stopped_state,
       stop_certificate
     ) @ #s

     &

     ToolExecutionAccepted(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #e

     ==>

     #e < #s"


lemma certified_stop_blocks_issued_certificate_execution:
  "All authority_pk verifier_pk command_id epoch
       agent_c_pk action_id tool arguments
       child_scope action_certificate stop_certificate
       #c #s #e.

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     &

     EmergencyStopIssued(
       authority_pk,
       command_id,
       epoch,
       'certified',
       stop_certificate
     ) @ #s

     &

     ToolExecutionAccepted(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #e

     ==>

     #e < #s"


lemma restart_requires_prior_emergency_stop:
  "All authority_pk command_id old_epoch new_epoch #r.

     CommandEpochRestarted(
       authority_pk,
       command_id,
       old_epoch,
       new_epoch
     ) @ #r

     ==>

     (Ex stopped_state stop_certificate #s.

       EmergencyStopIssued(
         authority_pk,
         command_id,
         old_epoch,
         stopped_state,
         stop_certificate
       ) @ #s

       & #s < #r)"


lemma stale_certificate_cannot_execute_after_restart:
  "All authority_pk verifier_pk command_id
       old_epoch new_epoch
       agent_c_pk action_id tool arguments
       child_scope action_certificate
       #c #r #e.

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       old_epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     &

     CommandEpochRestarted(
       authority_pk,
       command_id,
       old_epoch,
       new_epoch
     ) @ #r

     &

     ToolExecutionAccepted(
       authority_pk,
       verifier_pk,
       command_id,
       old_epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #e

     ==>

     #e < #r"


lemma action_certificate_requires_authority_authorized_action:
  "All authority_pk verifier_pk command_id epoch
       agent_c_pk action_id tool arguments
       child_scope action_certificate
       #c.

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     ==>

     (Ex allowed_action_digest #a.

       ExecutionScopeIssued(
         authority_pk,
         command_id,
         epoch,
         child_scope,
         allowed_action_digest
       ) @ #a

       &

       allowed_action_digest =
         h(<tool, arguments>)

       & #a < #c)"


lemma compromised_leaf_certificate_still_requires_authorized_action:
  "All authority_pk verifier_pk command_id epoch
       agent_c_pk action_id tool arguments
       child_scope action_certificate
       #k #p #c.

     AgentCompromised(
       'agent-c',
       agent_c_pk
     ) @ #k

     &

     CompromisedActionProposed(
       authority_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope
     ) @ #p

     &

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     & #k < #p
     & #p < #c

     ==>

     (Ex allowed_action_digest #a.

       ExecutionScopeIssued(
         authority_pk,
         command_id,
         epoch,
         child_scope,
         allowed_action_digest
       ) @ #a

       &

       allowed_action_digest =
         h(<tool, arguments>)

       & #a < #c)"


