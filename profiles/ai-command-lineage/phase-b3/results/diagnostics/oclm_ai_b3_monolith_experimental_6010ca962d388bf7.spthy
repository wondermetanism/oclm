lemma action_certificate_cannot_cross_epoch:
  "All authority_pk verifier_pk command_id
       issued_epoch executed_epoch
       agent_c_pk action_id tool arguments
       child_scope action_certificate
       #c #e.

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       issued_epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     &

     ToolExecutionAccepted(
       authority_pk,
       verifier_pk,
       command_id,
       executed_epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #e

     ==>

     issued_epoch = executed_epoch"



