       epoch,
       agent_b_pk,
       agent_c_pk,
       revocation_certificate
     ) @ #s

     & #c < #s"


lemma revoked_subtree_blocks_future_leaf_execution:
  "All authority_pk command_id epoch
       agent_b_pk agent_c_pk
       revocation_certificate
       #s.

     SubtreeRevocationIssued(
       authority_pk,
       command_id,
       epoch,
       agent_b_pk,
       agent_c_pk,
       revocation_certificate
     ) @ #s

     ==>

     not (
       Ex verifier_pk action_id tool arguments
          child_scope action_certificate #e.

       ToolExecutionAccepted(
         authority_pk,
         verifier_pk,
         command_id,
         epoch,
         agent_c_pk,
         action_id,
         tool,
         arguments,
         child_scope,
         action_certificate
       ) @ #e

       & #s < #e
     )"


lemma issued_certificate_dies_after_subtree_revocation:
  "All authority_pk verifier_pk command_id epoch
       agent_b_pk agent_c_pk
       action_id tool arguments child_scope
       action_certificate revocation_certificate
       #c #s.

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       agent_c_pk,
       action_id,
       tool,
       arguments,
       child_scope,
       action_certificate
     ) @ #c

     &

     SubtreeRevocationIssued(
       authority_pk,
       command_id,
       epoch,
       agent_b_pk,
       agent_c_pk,
       revocation_certificate
     ) @ #s

     & #c < #s

     ==>

     not (
       Ex #e.

       ToolExecutionAccepted(
         authority_pk,
         verifier_pk,
         command_id,
         epoch,
         agent_c_pk,
         action_id,
         tool,
         arguments,
         child_scope,
         action_certificate
       ) @ #e

       & #s < #e
     )"



/* =========================================================================
 * Replacement subtree properties.
 * ========================================================================= */

lemma compromised_subtree_can_be_replaced_and_execute:
  exists-trace
  "Ex authority_pk verifier_pk command_id epoch
      old_agent_b_pk old_agent_c_pk
      new_agent_b_pk new_agent_c_pk
      action_id tool arguments
      old_child_scope new_child_scope
      old_action_certificate new_action_certificate
      revocation_certificate replacement_certificate
      #k #old_c #s #r #p #new_c #e.

     AgentCompromised(
       'agent-b',
       old_agent_b_pk
     ) @ #k

     &

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       old_agent_c_pk,
       action_id,
       tool,
       arguments,
       old_child_scope,
       old_action_certificate
     ) @ #old_c

     &

     SubtreeRevocationIssued(
       authority_pk,
       command_id,
       epoch,
       old_agent_b_pk,
       old_agent_c_pk,
       revocation_certificate
     ) @ #s

     &

     SubtreeReplacementIssued(
       authority_pk,
       command_id,
       epoch,
       old_agent_b_pk,
       old_agent_c_pk,
       new_agent_b_pk,
       new_agent_c_pk,
       old_child_scope,
       new_child_scope,
       replacement_certificate
     ) @ #r

     &

     HonestActionProposed(
       authority_pk,
       command_id,
       epoch,
       new_agent_c_pk,
       action_id,
       tool,
       arguments,
       new_child_scope
     ) @ #p

     &

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       new_agent_c_pk,
       action_id,
       tool,
       arguments,
       new_child_scope,
       new_action_certificate
     ) @ #new_c

     &

     SubtreeLineageExecutionAccepted(
       authority_pk,
       command_id,
       epoch,
       new_agent_b_pk,
       new_agent_c_pk,
       new_child_scope,
       new_action_certificate
     ) @ #e

     & #k < #old_c
     & #old_c < #s
     & #s < #r
     & #r < #p
     & #p < #new_c
     & #new_c < #e"


lemma replacement_requires_prior_matching_subtree_revocation:
  "All authority_pk command_id epoch
       old_agent_b_pk old_agent_c_pk
       new_agent_b_pk new_agent_c_pk
       old_child_scope new_child_scope
       replacement_certificate
       #r.

     SubtreeReplacementIssued(
       authority_pk,
       command_id,
       epoch,
       old_agent_b_pk,
       old_agent_c_pk,
       new_agent_b_pk,
       new_agent_c_pk,
       old_child_scope,
       new_child_scope,
       replacement_certificate
     ) @ #r

     ==>

     (Ex revocation_certificate #s.

       SubtreeRevocationIssued(
         authority_pk,
         command_id,
         epoch,
         old_agent_b_pk,
         old_agent_c_pk,
         revocation_certificate
       ) @ #s

       & #s < #r)"


lemma replacement_execution_requires_fresh_leaf_certificate:
  "All authority_pk command_id epoch
       old_agent_b_pk old_agent_c_pk
       new_agent_b_pk new_agent_c_pk
       old_child_scope new_child_scope
       replacement_certificate action_certificate
       #r #e.

     SubtreeReplacementIssued(
       authority_pk,
       command_id,
       epoch,
       old_agent_b_pk,
       old_agent_c_pk,
       new_agent_b_pk,
       new_agent_c_pk,
       old_child_scope,
       new_child_scope,
       replacement_certificate
     ) @ #r

     &

     SubtreeLineageExecutionAccepted(
       authority_pk,
       command_id,
       epoch,
       new_agent_b_pk,
       new_agent_c_pk,
       new_child_scope,
       action_certificate
     ) @ #e

     & #r < #e

     ==>

     (Ex verifier_pk action_id tool arguments #c.

       ActionCertificateIssued(
         authority_pk,
         verifier_pk,
         command_id,
         epoch,
         new_agent_c_pk,
         action_id,
         tool,
         arguments,
         new_child_scope,
         action_certificate
       ) @ #c

       & #r < #c
       & #c < #e)"


lemma old_certificate_cannot_cross_into_replacement_subtree:
  "All authority_pk verifier_pk command_id epoch
       old_agent_b_pk old_agent_c_pk
       new_agent_b_pk new_agent_c_pk
       action_id tool arguments
       old_child_scope new_child_scope
       old_action_certificate replacement_certificate
       #c #r.

     ActionCertificateIssued(
       authority_pk,
       verifier_pk,
       command_id,
       epoch,
       old_agent_c_pk,
       action_id,
       tool,
       arguments,
       old_child_scope,
       old_action_certificate
     ) @ #c

     &

     SubtreeReplacementIssued(
       authority_pk,
       command_id,
       epoch,
       old_agent_b_pk,
       old_agent_c_pk,
       new_agent_b_pk,
       new_agent_c_pk,
       old_child_scope,
       new_child_scope,
       replacement_certificate
     ) @ #r

     & #c < #r

     ==>

     not (
       Ex #e.

       SubtreeLineageExecutionAccepted(
         authority_pk,
         command_id,
         epoch,
         new_agent_b_pk,
         new_agent_c_pk,
         new_child_scope,
         old_action_certificate
       ) @ #e

       & #r < #e
     )"


end
