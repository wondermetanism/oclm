/* =========================================================================
 * Generalized verifier compromise and reusable rollback
 * ========================================================================= */

rule Compromise_Generalized_Composition_Verifier:
  [
    !C6AMultiEpochContract(
      verifier,
      contract
    ),

    GeneralizedCompositionEpochState(
      verifier,
      contract,
      epoch,
      epoch_pk,
      lineage_root,
      'honest'
    ),

    CompromiseGeneralizedCompositionVerifierPermit(
      verifier,
      contract
    )
  ]
  --[
    GeneralizedCompositionVerifierCompromised(
      verifier,
      contract,
      epoch
    )
  ]->
  [
    !GeneralizedCompositionCompromiseState(
      verifier,
      contract
    ),

    GeneralizedCompositionEpochState(
      verifier,
      contract,
      epoch,
      epoch_pk,
      lineage_root,
      'compromised'
    ),

    StaleGeneralizedAcceptancePermit(
      verifier,
      contract
    )
  ]


rule Roll_Back_Generalized_Composition_One_Epoch:
  [
    GeneralizedCompositionEpochState(
      verifier,
      contract,
      higher_epoch,
      higher_epoch_pk,
      higher_lineage_root,
      'compromised'
    ),

    !GeneralizedCompositionCompromiseState(
      verifier,
      contract
    ),

    !GeneralizedCompositionTransition(
      contract,
      lower_epoch,
      higher_epoch
    ),

    !GeneralizedEpochRecord(
      contract,
      lower_epoch,
      lower_epoch_pk,
      lower_lineage_root
    )
  ]
  --[
    GeneralizedCompositionEpochRollback(
      verifier,
      contract,
      higher_epoch,
      lower_epoch
    )
  ]->
  [
    GeneralizedCompositionEpochState(
      verifier,
      contract,
      lower_epoch,
      lower_epoch_pk,
      lower_lineage_root,
      'compromised'
    )
  ]


