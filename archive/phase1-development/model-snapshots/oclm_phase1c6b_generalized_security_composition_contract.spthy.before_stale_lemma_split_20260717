lemma conflicting_generalized_epoch_histories_require_prior_compromise:
  "
    All verifier contract child_id certificate log checkpoint
        lower_epoch higher_epoch
        lower_epoch_pk lower_lineage_root
        higher_epoch_pk higher_lineage_root
        lower_transparency_root higher_transparency_root
        lower_revocation_mode higher_revocation_mode
        lower_transparency_mode higher_transparency_mode
        #it #ih #il.

          GeneralizedCompositionEpochTransition(
            contract,
            lower_epoch,
            higher_epoch
          ) @ #it

        & GeneralizedFinalAccepted(
            verifier,
            contract,
            child_id,
            certificate,
            log,
            checkpoint,
            higher_transparency_root,
            higher_epoch,
            higher_epoch_pk,
            higher_lineage_root,
