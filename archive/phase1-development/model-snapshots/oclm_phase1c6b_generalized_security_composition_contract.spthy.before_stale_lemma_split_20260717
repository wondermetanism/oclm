/* =========================================================================
 * Executability
 * ========================================================================= */

lemma executable_generalized_clean_multi_epoch_lifecycle:
  exists-trace
  "
    Ex verifier contract child_id certificate log
       canonical_transparency_root
       epoch_0 epoch_pk_0 lineage_root_0
       epoch_1
       epoch_2 epoch_pk_2 lineage_root_2
       #i0 #it1 #it2 #ia.

         GeneralizedSecurityCompositionInitialized(
           verifier,
           contract,
           child_id,
           certificate,
           log,
           's1',
           canonical_transparency_root,
           epoch_0,
           epoch_pk_0,
           lineage_root_0
         ) @ #i0

       & GeneralizedCompositionEpochTransition(
           contract,
           epoch_0,
           epoch_1
         ) @ #it1

       & GeneralizedCompositionEpochTransition(
           contract,
           epoch_1,
           epoch_2
         ) @ #it2

       & GeneralizedFinalAccepted(
           verifier,
           contract,
           child_id,
           certificate,
           log,
           's1',
           canonical_transparency_root,
           epoch_2,
           epoch_pk_2,
           lineage_root_2,
           'current',
           'active',
           'canonical'
         ) @ #ia

       & #i0 < #it1
       & #it1 < #it2
       & #it2 < #ia
  "


