           child_id,
           certificate,
           log,
           's1',
           canonical_transparency_root,
           epoch_0,
           epoch_pk_0,
           lineage_root_0,
           'stale',
           'revoked-compromised-verifier',
           'canonical'
         ) @ #iaccept_compromised

       & #i0 < #iepoch_compromise
       & #iepoch_compromise < #irevoke
       & #irevoke < #imissing
       & #imissing < #iaccept_missing
       & #iaccept_missing < #iapply
       & #iapply < #irevocation_compromise
       & #irevocation_compromise < #iaccept_compromised
  "


/* =========================================================================
 * Every final acceptance is anchored in both verified contracts
 * ========================================================================= */

lemma generalized_acceptance_requires_c5c_and_c6a_contracts:
  "
    All verifier contract child_id certificate log checkpoint
        transparency_root epoch epoch_pk lineage_root
        epoch_mode revocation_mode transparency_mode #ia.

      GeneralizedFinalAccepted(
        verifier,
        contract,
        child_id,
        certificate,
        log,
        checkpoint,
        transparency_root,
        epoch,
        epoch_pk,
        lineage_root,
        epoch_mode,
        revocation_mode,
        transparency_mode
      ) @ #ia

      ==>

      (Ex canonical_root initial_epoch initial_epoch_pk
          initial_lineage_root #ic5c #ic6a.

          C5CContractImported(
            verifier,
            contract,
            child_id,
            certificate,
            log,
            checkpoint,
            canonical_root
          ) @ #ic5c

        & C6AContractImported(
            verifier,
            contract,
            initial_epoch,
            initial_epoch_pk,
            initial_lineage_root
          ) @ #ic6a

        & #ic5c < #ia
        & #ic6a < #ia
      )
  "


