    ),

    GeneralizedFinalAccepted(
      verifier,
      contract,
      child_id,
      certificate,
      log,
      checkpoint,
      fork_transparency_root,
      epoch,
      epoch_pk,
      lineage_root,
      epoch_state,
      'active',
      'forked'
    )
  ]->
  [
    GeneralizedCompositionEpochState(
      verifier,
      contract,
      epoch,
      epoch_pk,
      lineage_root,
      epoch_state
    ),

    GeneralizedCertificateStatus(
      certificate,
      'active'
