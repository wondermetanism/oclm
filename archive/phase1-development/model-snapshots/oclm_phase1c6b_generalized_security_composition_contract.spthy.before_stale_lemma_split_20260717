theory OCLM_Phase1C6B_Generalized_Security_Composition_Contract
begin

/*
 * OCLM Phase 1-C6B
 *
 * Generalized Security Composition Contract
 *
 * This theory composes the already verified guarantees of:
 *
 *   Phase 1-C5C:
 *     revocation / transparency / lineage security composition
 *
 *   Phase 1-C6A:
 *     reusable multi-epoch successor and rollback resistance
 *
 * Both component interiors remain opaque. Their verified guarantees are
 * imported as assume-guarantee contract handles.
 *
 * The final acceptance decision binds:
 *
 *   - generalized epoch state
 *   - certificate revocation state
 *   - transparency checkpoint state
 *   - lineage/security composition contract
 *
 * Explicit exception paths:
 *
 *   stale epoch:
 *     prior generalized-verifier compromise
 *
 *   revoked certificate:
 *     missing revocation update
 *     or prior revocation-verifier compromise
 *
 *   forked transparency root:
 *     prior Transparency Log compromise
 *
 * Out of scope:
 *
 *   component-internal cryptography
 *   natural-number induction inside Tamarin
 *   Merkle-tree internals
 *   gossip availability
 *   witness quorum
 *   implementation refinement
 */


/* =========================================================================
 * Import the verified C5C and C6A contracts
 * ========================================================================= */

rule Import_Verified_C5C_And_C6A_Contracts:
  [
    Fr(~verifier),
    Fr(~contract),
    Fr(~child_id),
    Fr(~certificate),
    Fr(~log),
    Fr(~canonical_transparency_root),
    Fr(~epoch_0),
    Fr(~epoch_pk_0),
    Fr(~lineage_root_0)
  ]
  --[
    C5CContractImported(
      ~verifier,
      ~contract,
      ~child_id,
      ~certificate,
      ~log,
      's1',
      ~canonical_transparency_root
    ),

    C6AContractImported(
      ~verifier,
      ~contract,
      ~epoch_0,
      ~epoch_pk_0,
      ~lineage_root_0
    ),

    GeneralizedSecurityCompositionInitialized(
      ~verifier,
      ~contract,
      ~child_id,
      ~certificate,
      ~log,
      's1',
      ~canonical_transparency_root,
      ~epoch_0,
      ~epoch_pk_0,
      ~lineage_root_0
    )
  ]->
  [
    !C5CSecurityContract(
      ~verifier,
      ~contract,
      ~child_id,
      ~certificate,
      ~log,
      's1',
      ~canonical_transparency_root
    ),

    !C6AMultiEpochContract(
      ~verifier,
      ~contract
    ),

    !GeneralizedEpochRecord(
      ~contract,
      ~epoch_0,
      ~epoch_pk_0,
      ~lineage_root_0
    ),

    GeneralizedCompositionEpochState(
      ~verifier,
      ~contract,
      ~epoch_0,
      ~epoch_pk_0,
      ~lineage_root_0,
      'honest'
    ),

    GeneralizedCertificateStatus(
      ~certificate,
      'active'
    ),

    AdvanceGeneralizedCompositionEpochPermit(
      ~verifier,
      ~contract,
      ~epoch_0,
      ~epoch_pk_0,
      ~lineage_root_0
    ),

    CurrentGeneralizedAcceptancePermit(
      ~verifier,
      ~contract,
      ~epoch_0,
      ~epoch_pk_0,
      ~lineage_root_0
    ),

    CompromiseGeneralizedCompositionVerifierPermit(
      ~verifier,
      ~contract
    ),

    CompromiseGeneralizedTransparencyLogPermit(
      ~log,
      ~certificate,
      's1',
      ~canonical_transparency_root
    ),

    RevokeGeneralizedCertificatePermit(
      ~verifier,
      ~certificate
    )
  ]


/* =========================================================================
 * Reusable generalized epoch advancement
 * ========================================================================= */

rule Advance_Generalized_Composition_Epoch:
  [
    !C6AMultiEpochContract(
      verifier,
      contract
    ),

    GeneralizedCompositionEpochState(
      verifier,
      contract,
      lower_epoch,
      lower_epoch_pk,
      lower_lineage_root,
      'honest'
    ),

    AdvanceGeneralizedCompositionEpochPermit(
      verifier,
      contract,
      lower_epoch,
      lower_epoch_pk,
      lower_lineage_root
    ),

    Fr(~higher_epoch),
    Fr(~higher_epoch_pk),
    Fr(~higher_lineage_root)
  ]
  --[
    GeneralizedCompositionEpochTransition(
      contract,
      lower_epoch,
      ~higher_epoch
    ),

    GeneralizedCompositionEpochAdvanced(
      verifier,
      contract,
      lower_epoch,
      ~higher_epoch
    )
  ]->
  [
    !GeneralizedEpochRecord(
      contract,
      ~higher_epoch,
      ~higher_epoch_pk,
      ~higher_lineage_root
    ),

    !GeneralizedCompositionTransition(
      contract,
      lower_epoch,
      ~higher_epoch
    ),

    GeneralizedCompositionEpochState(
      verifier,
      contract,
      ~higher_epoch,
      ~higher_epoch_pk,
      ~higher_lineage_root,
      'honest'
    ),

    AdvanceGeneralizedCompositionEpochPermit(
      verifier,
      contract,
      ~higher_epoch,
      ~higher_epoch_pk,
      ~higher_lineage_root
    ),

    CurrentGeneralizedAcceptancePermit(
      verifier,
      contract,
      ~higher_epoch,
      ~higher_epoch_pk,
      ~higher_lineage_root
    )
  ]


/* =========================================================================
 * Clean acceptance at the current generalized epoch
 * ========================================================================= */

rule Accept_Clean_Generalized_Composition:
  [
    !C5CSecurityContract(
      verifier,
      contract,
      child_id,
      certificate,
      log,
      checkpoint,
      canonical_transparency_root
    ),

    !C6AMultiEpochContract(
      verifier,
      contract
    ),

    GeneralizedCompositionEpochState(
      verifier,
      contract,
      epoch,
      epoch_pk,
      lineage_root,
      'honest'
    ),

    GeneralizedCertificateStatus(
      certificate,
      'active'
    ),

    CurrentGeneralizedAcceptancePermit(
      verifier,
      contract,
      epoch,
      epoch_pk,
      lineage_root
    )
  ]
  --[
    GeneralizedEpochComponentSatisfied(
      verifier,
      contract,
      epoch,
      epoch_pk,
      lineage_root,
      'current'
    ),

    GeneralizedSecurityComponentSatisfied(
      verifier,
      contract,
      child_id,
      certificate,
      log,
      checkpoint,
      canonical_transparency_root,
      'active',
      'canonical'
    ),

    GeneralizedFinalAccepted(
      verifier,
      contract,
      child_id,
      certificate,
      log,
      checkpoint,
      canonical_transparency_root,
      epoch,
      epoch_pk,
      lineage_root,
      'current',
      'active',
      'canonical'
    )
  ]->
  [
    GeneralizedCompositionEpochState(
      verifier,
      contract,
      epoch,
      epoch_pk,
      lineage_root,
      'honest'
    ),

    GeneralizedCertificateStatus(
      certificate,
      'active'
    )
  ]


/* =========================================================================
 * Transparency Log compromise and forked acceptance
 * ========================================================================= */

rule Compromise_Generalized_Transparency_Log:
  [
    !C5CSecurityContract(
      verifier,
      contract,
      child_id,
      certificate,
      log,
      checkpoint,
      canonical_transparency_root
    ),

    CompromiseGeneralizedTransparencyLogPermit(
      log,
      certificate,
      checkpoint,
      canonical_transparency_root
    ),

    Fr(~fork_transparency_root)
  ]
  --[
    GeneralizedTransparencyLogCompromised(
      log,
      checkpoint,
      canonical_transparency_root
    ),

    GeneralizedConflictingTransparencyRootCreated(
      log,
      certificate,
      checkpoint,
      canonical_transparency_root,
      ~fork_transparency_root
    )
  ]->
  [
    !GeneralizedForkedTransparencyContract(
      certificate,
      log,
      checkpoint,
      canonical_transparency_root,
      ~fork_transparency_root
    ),

    ForkedGeneralizedAcceptancePermit(
      verifier,
      contract,
      certificate,
      log,
      checkpoint,
      ~fork_transparency_root
    )
  ]


rule Accept_Generalized_Composition_Under_Forked_Transparency:
  [
