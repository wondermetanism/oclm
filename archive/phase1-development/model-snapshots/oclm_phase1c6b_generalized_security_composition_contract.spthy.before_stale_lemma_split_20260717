    GeneralizedCertificateStatus(
      certificate,
      'active'
    ),

    RevokeGeneralizedCertificatePermit(
      verifier,
      certificate
    )
  ]
  --[
    GeneralizedCertificateRevoked(
      verifier,
      certificate
    ),

    GeneralizedRevocationUpdatePublished(
      verifier,
      certificate
    )
  ]->
  [
    GeneralizedCertificateStatus(
      certificate,
      'revoked'
    ),

    ObserveGeneralizedMissingUpdatePermit(
      verifier,
      certificate
    ),

    ApplyGeneralizedRevocationUpdatePermit(
      verifier,
      certificate
    )
  ]


